    "@tanstack/react-table": "^8.20.6",
    "clsx": "^2.1.1",
    "nuqs": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "react-router": "^7.1.1",
    "recharts": "^2.15.0",
